{
  "name": "ultracodex",
  "version": "0.2.0",
  "description": "Run Claude Code workflow scripts unmodified on the OpenAI Codex CLI — fable plans, codex executes, fable verifies",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/YuanpingSong/ultracodex.git"
  },
  "homepage": "https://github.com/YuanpingSong/ultracodex#readme",
  "bugs": {
    "url": "https://github.com/YuanpingSong/ultracodex/issues"
  },
  "keywords": [
    "agents",
    "orchestration",
    "codex",
    "claude-code",
    "workflow",
    "agent-script",
    "multi-agent",
    "cli",
    "tui"
  ],
  "type": "module",
  "bin": {
    "ultracodex": "dist/cli.js"
  },
  "files": [
    "dist",
    "examples",
    "docs/agent_script_spec.md",
    "README.md",
    "LICENSE",
    "NOTICE",
    "skills"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "pnpm build && pnpm test",
    "install:local": "pnpm build && pnpm link --global && echo \"installed: $(which ultracodex)\" && ultracodex --version",
    "release:check": "pnpm build && pnpm test && node scripts/release-check.mjs",
    "release": "node scripts/release.mjs"
  },
  "packageManager": "pnpm@10.12.4",
  "devDependencies": {
    "@types/node": "^26.1.0",
    "@types/react": "^19.2.17",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "acorn": "^8.17.0",
    "ajv": "^8.20.0",
    "commander": "^15.0.0",
    "ink": "^7.1.0",
    "picocolors": "^1.1.1",
    "react": "^19.2.7",
    "smol-toml": "^1.7.0"
  }
}
